# Database
# DATABASE_URL uses connection pooling (port 6543 for Supabase, or local port 5432)
DATABASE_URL=
# DIRECT_URL is the direct connection without pooling (used by Prisma for migrations)
DIRECT_URL=

# Docker Compose PostgreSQL (only used by docker-compose.yml)
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance_secret
POSTGRES_DB=finance_ai

# Google OAuth
GOOGLE_CLIENT_ID=
CLIENT_GOOGLE_SECRET=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Stripe
STRIPE_PREMIUM_PLAN_PRICE_ID=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_URL=
